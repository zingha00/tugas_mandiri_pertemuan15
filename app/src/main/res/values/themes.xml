<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════
         TEMA UTAMA I-Mo
         Base: Theme.Material3.Light.NoActionBar
         Kita pakai custom Toolbar di setiap Activity
         ══════════════════════════════════════════ -->
    <style name="Theme.IMo" parent="Theme.Material3.Light.NoActionBar">

        <!-- Warna sistem -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Tipografi default -->
        <item name="android:fontFamily">sans-serif</item>

    </style>

    <!-- ══════════════════════════════════════════
         STYLE TOOLBAR CUSTOM
         ══════════════════════════════════════════ -->
    <style name="IMo.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/text_on_primary</item>
        <item name="subtitleTextColor">@color/primary_light</item>
    </style>

    <!-- ══════════════════════════════════════════
         STYLE BUTTON
         ══════════════════════════════════════════ -->

    <!-- Tombol utama (simpan, tambah) -->
    <style name="IMo.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Tombol hapus (danger) -->
    <style name="IMo.Button.Danger" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/danger</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Tombol outline (batal) -->
    <style name="IMo.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- ══════════════════════════════════════════
         STYLE INPUT FIELD
         ══════════════════════════════════════════ -->
    <style name="IMo.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- ══════════════════════════════════════════
         STYLE CARD
         ══════════════════════════════════════════ -->
    <style name="IMo.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="contentPaddingLeft">16dp</item>
        <item name="contentPaddingRight">16dp</item>
        <item name="contentPaddingTop">16dp</item>
        <item name="contentPaddingBottom">16dp</item>
    </style>

</resources>