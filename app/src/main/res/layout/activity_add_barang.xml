<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══ APP BAR ══ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:navigationIcon="@drawable/ic_arrow_left"
            app:navigationIconTint="@color/text_on_primary"
            app:title="@string/title_tambah_barang"
            app:titleTextColor="@color/text_on_primary"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══ CONTENT ══ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card Form -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Label Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Informasi Barang"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp"/>

                    <!-- Nama Barang -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNamaBarang"
                        style="@style/IMo.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_nama_barang"
                        app:startIconDrawable="@drawable/ic_tag"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNamaBarang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Kategori -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilKategori"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/hint_kategori"
                        app:startIconDrawable="@drawable/ic_grid"
                        app:startIconTint="@color/primary"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/primary"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <AutoCompleteTextView
                            android:id="@+id/actvKategori"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Stok & Harga (2 kolom) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <!-- Stok -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilStok"
                            style="@style/IMo.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:hint="@string/hint_stok"
                            app:startIconDrawable="@drawable/ic_layer"
                            app:startIconTint="@color/primary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etStok"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Harga -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilHarga"
                            style="@style/IMo.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:hint="@string/hint_harga"
                            app:prefixText="Rp "
                            app:prefixTextColor="@color/text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etHarga"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"/>

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Deskripsi -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDeskripsi"
                        style="@style/IMo.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/hint_deskripsi"
                        app:startIconDrawable="@drawable/ic_file_text"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDeskripsi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="3"
                            android:maxLines="5"
                            android:gravity="top"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Tombol Simpan -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSimpan"
                style="@style/IMo.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/btn_simpan"
                app:icon="@drawable/ic_save"
                app:iconGravity="textStart"
                app:iconTint="@color/text_on_primary"/>

            <!-- Tombol Batal -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatal"
                style="@style/IMo.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_batal"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>